DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 窗口与上下文
MAX_WINDOW=10              # 保留最近几轮完整对话（越多越费Token）
DEFAULT_MODEL=deepseek-v4-flash  # 默认使用的模型
SIMILARITY_THRESHOLD=0.5   # 语义召回相似度阈值(0~1)，越大越精准，越小召回越多
SEMANTIC_TOP_K=4           # 语义召回最多带回几条旧消息
MAX_OUTPUT_TOKENS=4096     # 每次回复最多输出多少token，越大越完整但也越贵

# 摘要压缩
COMPRESSION_THRESHOLD_TOKENS=2000
COMPRESSION_MIN_RATIO=5.0

# 重试
MAX_RETRIES=3
RETRY_DELAY=2
